<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.JudsonsLibrary" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/p_light_pink</item>
        <item name="colorPrimaryVariant">@color/p_purple</item>
        <item name="colorOnPrimary">@color/p_white</item>

        <item name="colorSecondary">@color/p_teal</item>
        <item name="colorSecondaryVariant">@color/p_teal</item>
        <item name="colorOnSecondary">@color/p_purple</item>

        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <style name="itemListName">
        <item name="android:textSize">26sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:textColor">@color/p_blue</item>
    </style>

    <style name="itemName">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">10dp</item>
    </style>

    <style name="itemAmount">
        <item name="android:textSize">20sp</item>
        <item name="android:padding">20dp</item>
    </style>


    <style name="Theme.JudsonsLibrary" parent="Theme.MaterialComponents.Light.NoActionBar" />
</resources>