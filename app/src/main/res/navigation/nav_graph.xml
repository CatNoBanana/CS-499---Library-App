<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_library">


    <!--library home-->
    <fragment
        android:id="@+id/nav_library"
        android:name="com.zybooks.judsonsinventory.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library" />


    <!--books-->
    <fragment
        android:id="@+id/nav_books"
        android:name="com.zybooks.judsonsinventory.CategoryFragment"
        android:label="Books"
        tools:layout="@layout/fragment_category">
        <argument
            android:name="category"
            app:argType="string"
            android:defaultValue="Books" />
    </fragment>


    <!--movies-->
    <fragment
        android:id="@+id/nav_movies"
        android:name="com.zybooks.judsonsinventory.CategoryFragment"
        android:label="Movies"
        tools:layout="@layout/fragment_category">
        <argument
            android:name="category"
            app:argType="string"
            android:defaultValue="Movies" />
    </fragment>


    <!--games-->
    <fragment
        android:id="@+id/nav_games"
        android:name="com.zybooks.judsonsinventory.CategoryFragment"
        android:label="Games"
        tools:layout="@layout/fragment_category">
        <argument
            android:name="category"
            app:argType="string"
            android:defaultValue="Games" />
    </fragment>


    <!--profile-->
    <fragment
        android:id="@+id/nav_profile"
        android:name="com.zybooks.judsonsinventory.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

</navigation>